# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic
OPENAI_API_KEY=              # sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=           # sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
DEFAULT_TEMPERATURE=0.7

# ── Web Search ────────────────────────────────────
WEB_SEARCH_PROVIDER=mock     # mock | tavily | serper
WEB_SEARCH_API_KEY=          # API key for chosen provider

# ── API Authentication ────────────────────────────
API_KEY=                     # Leave empty to disable auth in dev

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_REQUESTS=60       # max requests per window
RATE_LIMIT_WINDOW=60         # window size in seconds

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=*               # comma-separated allowed origins

# ── Database ──────────────────────────────────────
DATABASE_URL=                # postgresql://user:pass@host:5432/db (optional)

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ChromaDB ──────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Metrics / Tracing ─────────────────────────────
ENABLE_METRICS=true
OTEL_EXPORTER_OTLP_ENDPOINT=  # http://localhost:4317 for OTLP

# ── Environment ───────────────────────────────────
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=INFO
