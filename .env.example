# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=openai           # openai | anthropic
OPENAI_API_KEY=               # sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=            # sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
DEFAULT_TEMPERATURE=0.7

# ── Web Search ────────────────────────────────────
WEB_SEARCH_PROVIDER=mock      # mock | tavily | serper
WEB_SEARCH_API_KEY=           # API key for chosen provider

# ── API Authentication ────────────────────────────
# Single legacy key (backwards-compatible, treated as admin)
API_KEY=                      # sk-... leave empty to disable auth in dev

# Multi-key JSON array (takes precedence over API_KEY)
# API_KEYS=[{"key":"sk-...","name":"ci-runner","role":"write"},{"key":"sk-...","name":"admin","role":"admin"}]

# JWT settings
JWT_SECRET=                   # auto-generated if empty (changes on each restart)
JWT_EXPIRY_SECONDS=3600       # token lifetime in seconds

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_REQUESTS=100       # max requests per window per client
RATE_LIMIT_WINDOW=60.0        # window size in seconds

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=*                # comma-separated origins, e.g. http://localhost:3000,https://app.example.com

# ── Persistence ───────────────────────────────────
DATABASE_URL=                 # postgresql://user:pass@host:5432/db (optional, for agent tools)
TASK_DB_PATH=tasks.db         # SQLite path for task record persistence (relative or absolute)

# ── Redis ─────────────────────────────────────────
REDIS_URL=                    # redis://localhost:6379 — leave empty to use asyncio in-process queue

# ── ChromaDB ──────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Logging & Observability ───────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json (production) | text (local dev)
OTEL_SERVICE_NAME=agi-system
OTEL_EXPORTER_OTLP_ENDPOINT=  # http://localhost:4317 for Jaeger/Tempo

# ── Server ────────────────────────────────────────
PORT=8000
